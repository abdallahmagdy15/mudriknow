{
  "name": "mudrik",
  "version": "1.2.0",
  "description": "Mudrik — a Windows tray AI assistant that perceives the UI element under your cursor and acts on it via UI Automation.",
  "main": "dist/main.js",
  "scripts": {
    "build": "webpack",
    "start": "npm run build && electron .",
    "dev": "webpack --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "check:no-env": "node scripts/check-no-env.js",
    "postinstall": "node scripts/prune-platform-bins.js",
    "pack:dir": "npm run build && electron-builder --win --dir",
    "dist": "npm run build && npm run check:no-env && electron-builder --win",
    "release": "npm run build && npm run check:no-env && electron-builder --win --publish always"
  },
  "keywords": [
    "electron",
    "windows",
    "ai-assistant",
    "uiautomation",
    "opencode",
    "mudrik"
  ],
  "author": "Mudrik contributors",
  "license": "MIT",
  "type": "commonjs",
  "dependencies": {
    "@opencode-ai/sdk": "^1.4.6",
    "electron-updater": "^6.8.3",
    "koffi": "^2.16.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "robotjs": "^0.7.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/ui": "^4.1.5",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^7.1.4",
    "electron": "^35.7.5",
    "electron-builder": "^26.8.1",
    "html-webpack-plugin": "^5.6.6",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.7",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5",
    "webpack": "^5.106.0",
    "webpack-cli": "^7.0.2"
  }
}
